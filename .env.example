# URL e chave do Supabase para uso server-side (rotas de API, server components)
SUPABASE_URL=
SUPABASE_KEY=

# Mesmas credenciais expostas ao client (prefixo NEXT_PUBLIC_ obrigatorio no Next.js)
# usadas em src/lib/supabase/client.ts e src/lib/supabase/middleware.ts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_KEY=
